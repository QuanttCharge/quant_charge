# Shared
NODE_ENV=development
LOG_LEVEL=info

# Postgres (Core API relational)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ev_cms
POSTGRES_USER=evcms
POSTGRES_PASSWORD=evcms_secret

# Prisma (Core API) — mirrors Postgres above
DATABASE_URL=postgresql://evcms:evcms_secret@localhost:5432/ev_cms?schema=public

# TimescaleDB (meter values)
TIMESCALE_HOST=localhost
TIMESCALE_PORT=5433
TIMESCALE_DB=ev_meter
TIMESCALE_USER=evcms
TIMESCALE_PASSWORD=evcms_secret

# Redis
REDIS_URL=redis://localhost:6379

# Kafka / Redpanda
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=ev-cms

# OCPP Gateway
OCPP_WS_PORT=9000
OCPP_INSTANCE_ID=ocpp-gw-1
OCPP_BASIC_AUTH_USER=charger
OCPP_BASIC_AUTH_PASS=charger_secret
OCPP_DRAIN_TIMEOUT_MS=60000
S3_RAW_LOG_BUCKET=ev-cms-ocpp-raw

# Core API
API_PORT=3000
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
OTP_TTL_SECONDS=300
SOCKET_IO_CORS_ORIGIN=*

# Razorpay (mock)
RAZORPAY_KEY_ID=rzp_test_mock
RAZORPAY_KEY_SECRET=mock_secret

# FCM / APNS (mock)
FCM_SERVER_KEY=mock_fcm_key
APNS_KEY_ID=mock_apns

# SMTP (mock)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@evcms.local

# OCPI
OCPI_TOKEN=ocpi_mock_token
